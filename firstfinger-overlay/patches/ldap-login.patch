index 5874d4b..93da96c 100644
--- a/api/user_session_test.go
+++ b/api/user_session_test.go
@@ -139,3 +139,44 @@ func Test_getListOfEnabledFeatures(t *testing.T) {
 		})
 	}
 }
+
+func Test_isLDAPSessionClaims(t *testing.T) {
+	tests := []struct {
+		name   string
+		claims map[string]interface{}
+		want   bool
+	}{
+		{
+			name:   "nil claims",
+			claims: nil,
+			want:   false,
+		},
+		{
+			name: "ldap user claim",
+			claims: map[string]interface{}{
+				"ldapUser": "CN=Richard Barbosa Silva,OU=Wiretest,OU=Testing,OU=CLICKIP,DC=clickip,DC=local",
+			},
+			want: true,
+		},
+		{
+			name: "ldap username claim",
+			claims: map[string]interface{}{
+				"ldapUsername": "richard.silva",
+			},
+			want: true,
+		},
+		{
+			name: "non ldap claims",
+			claims: map[string]interface{}{
+				"accessKey": "richard.silva",
+			},
+			want: false,
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(_ *testing.T) {
+			assert.Equal(t, tt.want, isLDAPSessionClaims(tt.claims))
+		})
+	}
+}
